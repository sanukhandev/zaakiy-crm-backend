{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "format": "prettier --write \"app/**/*.php\" \"config/**/*.php\" \"database/**/*.php\" \"routes/**/*.php\" \"tests/**/*.php\"",
        "format:check": "prettier --check \"app/**/*.php\" \"config/**/*.php\" \"database/**/*.php\" \"routes/**/*.php\" \"tests/**/*.php\""
    },
    "devDependencies": {
        "@prettier/plugin-php": "^0.24.0",
        "@tailwindcss/vite": "^4.0.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.0.0",
        "prettier": "^3.6.2",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    }
}
